{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the Golden Minds app (fellow, admin, or moderator).",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["fellow", "admin", "moderator"] },
        "avatar": { "type": "string" },
        "participationScore": { "type": "number" },
        "attendanceStreak": { "type": "number" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "Session": {
      "title": "Session",
      "description": "A scheduled learning or debate session.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "startTime": { "type": "string" },
        "endTime": { "type": "string" },
        "type": { "type": "string", "enum": ["lecture", "debate", "presentation"] },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        }
      },
      "required": ["title", "date", "startTime", "endTime", "type"]
    },
    "Attendance": {
      "title": "Attendance",
      "description": "A record of a user's attendance for a session.",
      "type": "object",
      "properties": {
        "sessionId": { "type": "string" },
        "userId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["present", "absent", "late"] },
        "geoVerified": { "type": "boolean" }
      },
      "required": ["sessionId", "userId", "timestamp", "status"]
    },
    "Material": {
      "title": "Material",
      "description": "Learning material for a session.",
      "type": "object",
      "properties": {
        "sessionId": { "type": "string" },
        "title": { "type": "string" },
        "url": { "type": "string" },
        "type": { "type": "string", "enum": ["pdf", "video", "slides"] },
        "aiSummary": { "type": "string" }
      },
      "required": ["sessionId", "title", "url", "type"]
    },
    "ForumPost": {
      "title": "ForumPost",
      "description": "A post in the community forum.",
      "type": "object",
      "properties": {
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "category": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "upvotes": { "type": "number" }
      },
      "required": ["authorId", "authorName", "title", "content", "category", "createdAt", "upvotes"]
    },
    "Debate": {
      "title": "Debate",
      "description": "A structured debate room.",
      "type": "object",
      "properties": {
        "topic": { "type": "string" },
        "status": { "type": "string", "enum": ["upcoming", "live", "completed"] },
        "teamA": {
          "type": "array",
          "items": { "type": "string" }
        },
        "teamB": {
          "type": "array",
          "items": { "type": "string" }
        },
        "aiScore": {
          "type": "object",
          "properties": {
            "teamA": { "type": "number" },
            "teamB": { "type": "number" },
            "summary": { "type": "string" }
          }
        }
      },
      "required": ["topic", "status", "teamA", "teamB"]
    },
    "AINote": {
      "title": "AINote",
      "description": "AI-generated notes and summaries for a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "sessionId": { "type": "string" },
        "content": { "type": "string" },
        "summary": { "type": "string" },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "content", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles."
    },
    "sessions/{sessionId}": {
      "schema": "Session",
      "description": "Scheduled sessions."
    },
    "attendance/{attendanceId}": {
      "schema": "Attendance",
      "description": "Attendance records."
    },
    "materials/{materialId}": {
      "schema": "Material",
      "description": "Learning materials."
    },
    "forum_posts/{postId}": {
      "schema": "ForumPost",
      "description": "Community forum posts."
    },
    "debates/{debateId}": {
      "schema": "Debate",
      "description": "Debate rooms."
    },
    "ai_notes/{noteId}": {
      "schema": "AINote",
      "description": "AI-generated notes."
    }
  }
}
